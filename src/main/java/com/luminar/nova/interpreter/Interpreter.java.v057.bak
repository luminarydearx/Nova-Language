package com.luminar.nova.interpreter;

import com.luminar.nova.parser.ast.*;

import java.util.*;

public final class Interpreter {

    final Deque<NovaInstance> thisStack = new ArrayDeque<>();
    private final Environment globals = new Environment();
    private Environment env = globals;

    public Interpreter() { registerBuiltins(); }

    public void execute(ProgramNode program) {
        for (Node stmt : program.statements()) execNode(stmt);
    }

    public void executeBlock(BlockNode block, Environment blockEnv) {
        Environment prev = this.env;
        this.env = blockEnv;
        try { for (Node stmt : block.statements()) execNode(stmt); }
        finally { this.env = prev; }
    }

    private void execNode(Node node) {
        switch (node) {
            case ProgramNode p        -> execute(p);
            case PrintNode p          -> System.out.println(str(eval(p.expr())));
            case VarDeclNode v        -> execVarDecl(v);
            case ExprStmtNode e       -> eval(e.expr());
            case BlockNode b          -> executeBlock(b, new Environment(env));
            case FunctionDeclNode f   -> execFuncDecl(f);
            case ClassDeclNode c      -> execClassDecl(c);
            case InterfaceDeclNode i  -> execInterfaceDecl(i);
            case EnumDeclNode e       -> execEnumDecl(e);
            case StructDeclNode s     -> execStructDecl(s);
            case ReturnNode r         -> throw new ReturnSignal(r.value() != null ? eval(r.value()) : null);
            case BreakNode ignored    -> throw new BreakSignal();
            case ContinueNode ignored -> throw new ContinueSignal();
            case IfNode i             -> execIf(i);
            case WhileNode w          -> execWhile(w);
            case DoWhileNode d        -> execDoWhile(d);
            case ForNode f            -> execFor(f);
            case TryCatchNode t       -> execTryCatch(t);
            case ThrowNode t          -> throw new NovaException(eval(t.value()));
            case null -> {}
            default -> throw new NovaRuntimeError("Unknown node type: " + node.getClass().getSimpleName());
        }
    }

    private void execVarDecl(VarDeclNode v) {
        Object value = v.initializer() != null ? eval(v.initializer()) : null;
        if (v.typeAnno() != null) value = coerce(v.typeAnno(), value, "variable '" + v.name() + "'");
        env.define(v.name(), value, v.isConst());
    }

    private void execFuncDecl(FunctionDeclNode f) {
        if (f.isAbstract()) throw new NovaRuntimeError("Abstract method '" + f.name() + "' cannot be declared outside a class");
        env.define(f.name(), new NovaFunction(f.name(), f.params(), f.paramTypes(), f.returnType(), f.body(), env));
    }

    private void execClassDecl(ClassDeclNode c) {
        NovaClass superclass = null;
        if (c.superclassName() != null) {
            Object s = env.get(c.superclassName());
            if (!(s instanceof NovaClass nc)) throw new NovaRuntimeError("'" + c.superclassName() + "' is not a class");
            superclass = nc;
        }
        Map<String, NovaCallable> methods = new LinkedHashMap<>();
        Map<String, String> visibilities = new LinkedHashMap<>();
        for (FunctionDeclNode m : c.methods()) {
            if (m.isAbstract()) {
                final String mname = m.name();
                methods.put(mname, new NativeFunction((interp, args) -> { throw new NovaRuntimeError("Abstract method '" + mname + "' not implemented"); }));
            } else {
                methods.put(m.name(), new NovaFunction(m.name(), m.params(), m.paramTypes(), m.returnType(), m.body(), env));
            }
            visibilities.put(m.name(), m.visibility());
        }
        if (!c.isAbstract()) {
            for (String ifName : c.interfaceNames()) {
                Object ifObj = env.isDefined(ifName) ? env.get(ifName) : null;
                if (ifObj instanceof NovaInterface novaIface) {
                    NovaClass tmpClass = new NovaClass(c.name(), methods, visibilities, superclass, false, c.interfaceNames(), c.fields());
                    novaIface.checkImplementedBy(tmpClass);
                }
            }
        }
        for (VarDeclNode v : c.fields()) {
            visibilities.put(v.name(), v.visibility());
        }
        NovaClass klass = new NovaClass(c.name(), methods, visibilities, superclass, c.isAbstract(), c.interfaceNames(), c.fields());
        env.define(c.name(), klass);
    }

    private void execInterfaceDecl(InterfaceDeclNode i) {
        Set<String> required = new LinkedHashSet<>();
        for (var m : i.methods()) required.add(m.name());
        for (String p : i.parentInterfaces()) {
            Object pi = env.isDefined(p) ? env.get(p) : null;
            if (pi instanceof NovaInterface pIface) required.addAll(pIface.requiredMethods);
        }
        env.define(i.name(), new NovaInterface(i.name(), required, i.parentInterfaces()));
    }

    private void execEnumDecl(EnumDeclNode e) { env.define(e.name(), new NovaEnum(e.name(), e.values())); }

    private void execStructDecl(StructDeclNode s) {
        List<String> fnames = s.fields().stream().map(StructField::name).toList();
        List<String> ftypes = s.fields().stream().map(StructField::type).toList();
        NativeFunction initFn = new NativeFunction((interp, args) -> {
            NovaInstance inst = interp.thisStack.peek();
            for (int i = 0; i < fnames.size(); i++) {
                Object val = i < args.size() ? args.get(i) : null;
                if (ftypes.get(i) != null) val = interp.coerce(ftypes.get(i), val, "struct field '" + fnames.get(i) + "'");
                inst.set(fnames.get(i), val);
            }
            return null;
        });
        NativeFunction toStringFn = new NativeFunction((interp, args) -> {
            NovaInstance inst = interp.thisStack.peek();
            StringJoiner sj = new StringJoiner(", ", s.name() + "(", ")");
            for (String fn : fnames) sj.add(fn + ": " + interp.str(inst.fields.get(fn)));
            return sj.toString();
        });
        Map<String, NovaCallable> methods = new LinkedHashMap<>();
        methods.put("init", initFn); methods.put("toString", toStringFn);
        Map<String, String> visibilities = new LinkedHashMap<>();
        visibilities.put("init", "public"); visibilities.put("toString", "public");
        env.define(s.name(), new NovaClass(s.name(), methods, visibilities, null, false, List.of(), List.of()));
    }

    private void execIf(IfNode node) {
        if (truthy(eval(node.condition()))) executeBlock(node.thenBranch(), new Environment(env));
        else if (node.elseBranch() != null) {
            if (node.elseBranch() instanceof BlockNode b) executeBlock(b, new Environment(env));
            else execNode(node.elseBranch());
        }
    }

    private void execWhile(WhileNode node) {
        while (truthy(eval(node.condition()))) {
            try { executeBlock(node.body(), new Environment(env)); }
            catch (BreakSignal e) { break; } catch (ContinueSignal e) { /* continue */ }
        }
    }

    private void execDoWhile(DoWhileNode node) {
        do {
            try { executeBlock(node.body(), new Environment(env)); }
            catch (BreakSignal e) { break; } catch (ContinueSignal e) { /* continue */ }
        } while (truthy(eval(node.condition())));
    }

    private void execFor(ForNode node) {
        Object iterable = eval(node.iterable());
        Iterable<?> items;
        if (iterable instanceof List<?>) items = (List<?>)iterable;
        else if (iterable instanceof NovaRange) items = (NovaRange)iterable;
        else throw new NovaRuntimeError("'for' requires an iterable (array or range)");
        for (Object item : items) {
            Environment loopEnv = new Environment(env);
            loopEnv.define(node.varName(), item);
            try { executeBlock(node.body(), loopEnv); }
            catch (BreakSignal e) { break; } catch (ContinueSignal e) { /* next */ }
        }
    }

    private void execTryCatch(TryCatchNode node) {
        Runnable runFin = () -> { if (node.finallyBlock() != null) executeBlock(node.finallyBlock(), new Environment(env)); };
        try {
            executeBlock(node.tryBlock(), new Environment(env));
            runFin.run();
        } catch (NovaException e) {
            runFin.run();
            if (node.catchBlock() != null) {
                Environment cEnv = new Environment(env);
                cEnv.define(node.catchVar(), e.thrown);
                executeBlock(node.catchBlock(), cEnv);
            }
        } catch (NovaRuntimeError e) {
            runFin.run();
            if (node.catchBlock() != null) {
                Map<String, Object> errObj = new LinkedHashMap<>();
                errObj.put("message", e.getMessage()); errObj.put("name", "RuntimeError");
                Environment cEnv = new Environment(env);
                cEnv.define(node.catchVar(), errObj);
                executeBlock(node.catchBlock(), cEnv);
            } else throw e;
        }
    }

    Object eval(ExprNode expr) {
        return switch (expr) {
            case ExprNode.Lit lit        -> lit.value();
            case ExprNode.Id id          -> env.get(id.name());
            case ExprNode.CmpIdSet ci    -> {
                Object cur = env.get(ci.name());
                Object val = "=".equals(ci.op()) ? eval(ci.value()) : arithmetic(cur, ci.op(), eval(ci.value()));
                env.assign(ci.name(), val); yield val;
            }
            case ExprNode.ThisExpr ignored -> {
                if (thisStack.isEmpty()) throw new NovaRuntimeError("'this' outside a method");
                yield thisStack.peek();
            }
            case ExprNode.Grouping g     -> eval(g.expr());
            case ExprNode.Unary u        -> evalUnary(u);
            case ExprNode.Binary b       -> evalBinary(b);
            case ExprNode.Postfix p      -> evalPostfix(p);
            case ExprNode.Prefix p       -> evalPrefix(p);
            case ExprNode.ArrayLit a     -> evalArrayLit(a);
            case ExprNode.ObjLit o       -> evalObjectLit(o);
            case ExprNode.Call c         -> evalCall(c);
            case ExprNode.NewExpr n      -> evalNew(n);
            case ExprNode.SuperCall s    -> evalSuper(s);
            case ExprNode.IndexGet ig    -> evalIndex(ig);
            case ExprNode.MemberGet mg   -> evalMember(mg);
            case ExprNode.IndexSet is    -> evalIndexAssign(is);
            case ExprNode.MemberSet ms   -> evalMemberAssign(ms);
            case ExprNode.CmpMemberSet cms -> evalCmpMemberAssign(cms);
            case ExprNode.CmpIndexSet cis -> evalCmpIndexAssign(cis);
            case ExprNode.Ternary t      -> truthy(eval(t.condition())) ? eval(t.thenExpr()) : eval(t.elseExpr());
            case ExprNode.Await a        -> evalAwait(a);
            case ExprNode.FuncExpr f     -> new NovaFunction(null, f.params(), f.paramTypes(), f.returnType(), f.body(), env);
            default -> throw new NovaRuntimeError("Unknown expression type: " + expr.getClass().getSimpleName());
        };
    }

    private Object evalAwait(ExprNode.Await a) {
        Object val = eval(a.expr());
        if (val instanceof java.util.concurrent.CompletableFuture<?> future) {
            try { return future.get(); }
            catch (Exception e) { throw new NovaRuntimeError("Await failed: " + e.getMessage()); }
        }
        return val;
    }

    private Object evalUnary(ExprNode.Unary u) {
        Object v = eval(u.operand());
        return switch (u.op()) { case "-" -> negate(v); case "!" -> !truthy(v); default -> throw new NovaRuntimeError("Unknown unary op: " + u.op()); };
    }

    private Object evalBinary(ExprNode.Binary b) {
        if ("&&".equals(b.op())) return truthy(eval(b.left())) && truthy(eval(b.right()));
        if ("||".equals(b.op())) return truthy(eval(b.left())) || truthy(eval(b.right()));
        Object L = eval(b.left()), R = eval(b.right());
        return switch (b.op()) {
            case "+" -> addOrConcat(L, R);
            case "-" -> arithmetic(L, "-", R);
            case "*" -> arithmetic(L, "*", R);
            case "/" -> {
                if (L instanceof Long && R instanceof Long) {
                    long r = (long) R;
                    if (r == 0) throw new NovaRuntimeError("Division by zero");
                    yield (long) L / r;
                }
                double r = num(R);
                if (r == 0) throw new NovaRuntimeError("Division by zero");
                yield num(L) / r;
            }
            case "%" -> arithmetic(L, "%", R);
            case "**" -> Math.pow(num(L), num(R));
            case "<" -> cmp(L, R) < 0; case "<=" -> cmp(L, R) <= 0; case ">" -> cmp(L, R) > 0; case ">=" -> cmp(L, R) >= 0;
            case "==" -> eq(L, R); case "!=" -> !eq(L, R);
            case ".." -> new NovaRange(toLong(L), toLong(R));
            default -> throw new NovaRuntimeError("Unknown operator: " + b.op());
        };
    }

    private Object evalPostfix(ExprNode.Postfix p) {
        Object old = eval(p.operand());
        writeBack(p.operand(), "++".equals(p.op()) ? incr(old) : decr(old));
        return old;
    }

    private Object evalPrefix(ExprNode.Prefix p) {
        Object nw = "++".equals(p.op()) ? incr(eval(p.operand())) : decr(eval(p.operand()));
        writeBack(p.operand(), nw);
        return nw;
    }

    private void writeBack(ExprNode target, Object value) {
        switch (target) {
            case ExprNode.Id id -> env.assign(id.name(), value);
            case ExprNode.MemberGet mg -> {
                Object obj = eval(mg.obj());
                if (obj instanceof NovaInstance ni) ni.set(mg.member(), value);
                else if (obj instanceof Map<?,?> m) ((Map<String,Object>)m).put(mg.member(), value);
                else throw new NovaRuntimeError("Cannot set property on " + typeName(obj));
            }
            case ExprNode.IndexGet ig -> {
                Object obj = eval(ig.obj()); int i = (int)toLong(eval(ig.index()));
                if (obj instanceof List<?> l) ((List<Object>)l).set(i, value);
                else throw new NovaRuntimeError("Cannot set index on " + typeName(obj));
            }
            default -> throw new NovaRuntimeError("Invalid write target");
        }
    }

    private Object evalArrayLit(ExprNode.ArrayLit a) {
        List<Object> l = new ArrayList<>();
        for (ExprNode e : a.elements()) l.add(eval(e));
        return l;
    }

    private Map<String,Object> evalObjectLit(ExprNode.ObjLit o) {
        Map<String,Object> m = new LinkedHashMap<>();
        for (var e : o.entries()) m.put(e.getKey(), eval(e.getValue()));
        return m;
    }

    private Object evalCall(ExprNode.Call c) {
        if (c.callee() instanceof ExprNode.MemberGet mg) return evalMethodCall(mg, c.args());
        Object callee = eval(c.callee());
        List<Object> args = c.args().stream().map(this::eval).toList();
        if (callee instanceof NovaCallable fn) return fn.call(this, args);
        throw new NovaRuntimeError("'" + str(callee) + "' is not callable");
    }

    @SuppressWarnings("unchecked")
    private Object evalMethodCall(ExprNode.MemberGet mg, List<ExprNode> argExprs) {
        Object obj = eval(mg.obj()); String name = mg.member();
        List<Object> args = argExprs.stream().map(this::eval).toList();
        if (obj instanceof NovaInstance ni) {
            checkVisibility(ni.klass, name);
            Object m = ni.get(name, this);
            if (m instanceof NovaCallable fn) {
                thisStack.push(ni); try { return fn.call(this, args); } finally { thisStack.pop(); }
            }
            throw new NovaRuntimeError("'" + name + "' is not callable on " + ni.klass.name);
        }
        if (obj instanceof List<?>) return listMethod((List<Object>)obj, name, args);
        if (obj instanceof String) return strMethod((String)obj, name, args);
        if (obj instanceof Map<?,?>) return mapMethod((Map<String,Object>)obj, name, args);
        throw new NovaRuntimeError(typeName(obj) + " has no method '" + name + "'");
    }

    private void checkVisibility(NovaClass klass, String mname) {
        String vis = klass.getVisibility(mname);
        if ("public".equals(vis)) return;
        if ("private".equals(vis)) {
            if (!thisStack.isEmpty() && thisStack.peek().klass == klass) return;
            throw new NovaRuntimeError("Cannot access private member '" + mname + "'");
        }
        if ("protected".equals(vis)) {
            if (!thisStack.isEmpty() && thisStack.peek().klass.isSubclassOf(klass)) return;
            throw new NovaRuntimeError("Cannot access protected member '" + mname + "'");
        }
    }

    private Object evalNew(ExprNode.NewExpr n) {
        Object co = env.get(n.className());
        List<Object> args = n.args().stream().map(this::eval).toList();
        if (co instanceof NovaCallable fn) return fn.call(this, args);
        throw new NovaRuntimeError("'" + n.className() + "' is not a class");
    }

    private Object evalSuper(ExprNode.SuperCall s) {
        if (thisStack.isEmpty()) throw new NovaRuntimeError("'super' outside method");
        NovaInstance inst = thisStack.peek();
        if (inst.klass.superclass == null) throw new NovaRuntimeError("No superclass");
        NovaCallable m = inst.klass.superclass.findMethod(s.method());
        if (m == null) throw new NovaRuntimeError("Superclass has no method '" + s.method() + "'");
        List<Object> args = s.args().stream().map(this::eval).toList();
        return m.bind(inst).call(this, args);
    }

    @SuppressWarnings("unchecked")
    private Object evalIndex(ExprNode.IndexGet ig) {
        Object obj = eval(ig.obj()), idx = eval(ig.index());
        if (obj instanceof List<?> l) {
            int i = (int)toLong(idx); if (i < 0) i = l.size() + i;
            if (i < 0 || i >= l.size()) throw new NovaRuntimeError("Index out of bounds: " + i);
            return ((List<Object>)l).get(i);
        }
        if (obj instanceof Map<?,?> m) return ((Map<String,Object>)m).get(str(idx));
        if (obj instanceof String s) {
            int i = (int)toLong(idx); if (i < 0) i = s.length() + i;
            return (i >= 0 && i < s.length()) ? String.valueOf(s.charAt(i)) : null;
        }
        throw new NovaRuntimeError("Cannot index " + typeName(obj));
    }

    @SuppressWarnings("unchecked")
    private Object evalMember(ExprNode.MemberGet mg) {
        Object obj = eval(mg.obj()); String n = mg.member();
        if (obj instanceof NovaInstance ni) { checkVisibility(ni.klass, n); return ni.get(n, this); }
        if (obj instanceof NovaEnum ne) return ne.get(n);
        if (obj instanceof NovaEnumValue nev) return nev.get(n);
        if (obj instanceof Map<?,?> m) return ((Map<String,Object>)m).get(n);
        if (obj instanceof List<?> l) {
            if ("length".equals(n) || "len".equals(n)) return (long)l.size();
            return null;
        }
        if (obj instanceof String s) {
            if ("length".equals(n) || "len".equals(n)) return (long)s.length();
            return null;
        }
        if (obj instanceof java.util.concurrent.CompletableFuture<?> future) {
            if ("result".equals(n)) {
                try { return future.get(); }
                catch (Exception e) { throw new NovaRuntimeError("Failed to get task result: " + e.getMessage()); }
            }
            if ("isDone".equals(n)) return future.isDone();
        }
        throw new NovaRuntimeError("No property '" + n + "' on " + typeName(obj));
    }

    @SuppressWarnings("unchecked")
    private Object evalIndexAssign(ExprNode.IndexSet is) {
        Object obj = eval(is.obj()), idx = eval(is.index()), val = eval(is.value());
        if (obj instanceof List<?>) { ((List<Object>)obj).set((int)toLong(idx), val); return val; }
        if (obj instanceof Map<?,?>) { ((Map<String,Object>)obj).put(str(idx), val); return val; }
        throw new NovaRuntimeError("Cannot assign index");
    }

    @SuppressWarnings("unchecked")
    private Object evalMemberAssign(ExprNode.MemberSet ms) {
        Object obj = eval(ms.obj()), val = eval(ms.value());
        if (obj instanceof NovaInstance ni) { ni.set(ms.member(), val); return val; }
        if (obj instanceof Map<?,?>) { ((Map<String,Object>)obj).put(ms.member(), val); return val; }
        throw new NovaRuntimeError("Cannot assign member");
    }

    @SuppressWarnings("unchecked")
    private Object evalCmpMemberAssign(ExprNode.CmpMemberSet cms) {
        Object obj = eval(cms.obj());
        if (obj instanceof NovaInstance ni) {
            Object cur = ni.get(cms.member(), this);
            Object val = arithmetic(cur, cms.op(), eval(cms.value()));
            ni.set(cms.member(), val); return val;
        }
        if (obj instanceof Map<?,?> m) {
            Object cur = ((Map<String,Object>)m).get(cms.member());
            Object val = arithmetic(cur, cms.op(), eval(cms.value()));
            ((Map<String,Object>)m).put(cms.member(), val); return val;
        }
        throw new NovaRuntimeError("Cannot compound assign member");
    }

    @SuppressWarnings("unchecked")
    private Object evalCmpIndexAssign(ExprNode.CmpIndexSet cis) {
        Object obj = eval(cis.obj()); int i = (int)toLong(eval(cis.index()));
        if (obj instanceof List<?>) {
            Object cur = ((List<Object>)obj).get(i);
            Object val = arithmetic(cur, cis.op(), eval(cis.value()));
            ((List<Object>)obj).set(i, val); return val;
        }
        if (obj instanceof Map<?,?> m) {
            String k = str(eval(cis.index()));
            Object cur = ((Map<String,Object>)m).get(k);
            Object val = arithmetic(cur, cis.op(), eval(cis.value()));
            ((Map<String,Object>)m).put(k, val); return val;
        }
        throw new NovaRuntimeError("Cannot compound assign index");
    }

    private Object listMethod(List<Object> arr, String name, List<Object> args) {
        return switch (name) {
            case "push" -> { arr.addAll(args); yield null; } 
            case "pop" -> arr.isEmpty() ? null : arr.remove(arr.size()-1); 
            case "len","length" -> (long)arr.size(); 
            case "join" -> {
                String sep = args.isEmpty() ? "" : str(args.get(0));
                StringJoiner sj = new StringJoiner(sep);
                for (Object o : arr) sj.add(str(o));
                yield sj.toString();
            }
            case "slice" -> {
                int start = args.isEmpty() ? 0 : (int)toLong(args.get(0));
                int end = args.size() < 2 ? arr.size() : (int)toLong(args.get(1));
                if (start < 0) start = arr.size() + start;
                if (end < 0) end = arr.size() + end;
                start = Math.max(0, Math.min(arr.size(), start));
                end = Math.max(0, Math.min(arr.size(), end));
                if (start >= end) yield new ArrayList<>();
                yield new ArrayList<>(arr.subList(start, end));
            }
            case "contains" -> arr.contains(args.isEmpty() ? null : args.get(0));
            case "reverse" -> { Collections.reverse(arr); yield arr; }
            case "clear" -> { arr.clear(); yield null; }
            default -> throw new NovaRuntimeError("No array method " + name);
        };
    }

    private Object strMethod(String s, String name, List<Object> args) {
        return switch (name) { 
            case "upper" -> s.toUpperCase(); 
            case "lower" -> s.toLowerCase(); 
            case "len","length" -> (long)s.length(); 
            case "split" -> {
                String sep = args.isEmpty() ? "" : str(args.get(0));
                if (sep.isEmpty()) yield new ArrayList<>(Arrays.asList(s.split("")));
                yield new ArrayList<>(Arrays.asList(s.split(java.util.regex.Pattern.quote(sep))));
            }
            case "trim" -> s.trim();
            case "replace" -> {
                if (args.size() < 2) throw new NovaRuntimeError("replace requires 2 arguments");
                yield s.replace(str(args.get(0)), str(args.get(1)));
            }
            case "contains" -> s.contains(args.isEmpty() ? "" : str(args.get(0)));
            case "startsWith" -> s.startsWith(args.isEmpty() ? "" : str(args.get(0)));
            case "endsWith" -> s.endsWith(args.isEmpty() ? "" : str(args.get(0)));
            case "slice" -> {
                int start = args.isEmpty() ? 0 : (int)toLong(args.get(0));
                int end = args.size() < 2 ? s.length() : (int)toLong(args.get(1));
                if (start < 0) start = s.length() + start;
                if (end < 0) end = s.length() + end;
                start = Math.max(0, Math.min(s.length(), start));
                end = Math.max(0, Math.min(s.length(), end));
                if (start >= end) yield "";
                yield s.substring(start, end);
            }
            default -> throw new NovaRuntimeError("No string method " + name); 
        };
    }

    private Object mapMethod(Map<String,Object> m, String name, List<Object> args) {
        return switch (name) { 
            case "keys" -> new ArrayList<>(m.keySet()); 
            case "values" -> new ArrayList<>(m.values());
            case "has" -> m.containsKey(args.isEmpty() ? null : str(args.get(0)));
            case "remove" -> m.remove(args.isEmpty() ? null : str(args.get(0)));
            case "len","length" -> (long)m.size(); 
            case "clear" -> { m.clear(); yield null; }
            default -> throw new NovaRuntimeError("No map method " + name); 
        };
    }

    private void registerBuiltins() {
        globals.define("print", new NativeFunction((interp, args) -> { System.out.println(str(args.isEmpty() ? null : args.get(0))); return null; }));
        globals.define("int", new NativeFunction((interp, args) -> toLong(args.isEmpty() ? 0L : args.get(0))));
        globals.define("float", new NativeFunction((interp, args) -> num(args.isEmpty() ? 0.0 : args.get(0))));
        globals.define("PI", Math.PI);
        globals.define("str", new NativeFunction((interp, args) -> str(args.isEmpty() ? null : args.get(0))));
        globals.define("typeOf", new NativeFunction((interp, args) -> typeName(args.isEmpty() ? null : args.get(0))));
        globals.define("abs", new NativeFunction((interp, args) -> {
            Object v = args.isEmpty() ? 0L : args.get(0);
            if (v instanceof Long l) return Math.abs(l);
            return Math.abs(num(v));
        }));
        globals.define("range", new NativeFunction((interp, args) -> {
            long from = args.isEmpty() ? 0 : toLong(args.get(0));
            long to = args.size() < 2 ? from : toLong(args.get(1));
            if (args.size() < 2) from = 0;
            return new NovaRange(from, to);
        }));
        globals.define("spawn", new NativeFunction((interp, args) -> {
            if (args.isEmpty() || !(args.get(0) instanceof NovaCallable fn)) throw new NovaRuntimeError("spawn requires a function");
            return java.util.concurrent.CompletableFuture.supplyAsync(() -> fn.call(interp, new ArrayList<>()));
        }));
        globals.define("VERSION", "0.5.7");
    }

    Object coerce(String type, Object val, String ctx) {
        if (type == null || "any".equals(type)) return val;
        return switch (type) {
            case "int" -> toLong(val); 
            case "float" -> num(val); 
            case "string" -> str(val); 
            case "bool" -> truthy(val);
            default -> val;
        };
    }

    private Object addOrConcat(Object L, Object R) {
        if (L instanceof String || R instanceof String) return str(L) + str(R);
        return arithmetic(L, "+", R);
    }

    Object arithmetic(Object L, String op, Object R) {
        if (L instanceof Number n1 && R instanceof Number n2) {
            if (n1 instanceof Long && n2 instanceof Long) {
                long l1 = n1.longValue(), l2 = n2.longValue();
                return switch (op) {
                    case "+" -> l1 + l2;
                    case "-" -> l1 - l2;
                    case "*" -> l1 * l2;
                    case "/" -> { if (l2 == 0) throw new NovaRuntimeError("Division by zero"); yield l1 / l2; }
                    case "%" -> { if (l2 == 0) throw new NovaRuntimeError("Modulo by zero");   yield l1 % l2; }
                    default  -> 0L;
                };
            }
            double d1 = n1.doubleValue(), d2 = n2.doubleValue();
            return switch (op) {
                case "+" -> d1 + d2;
                case "-" -> d1 - d2;
                case "*" -> d1 * d2;
                case "/" -> { if (d2 == 0) throw new NovaRuntimeError("Division by zero"); yield d1 / d2; }
                case "%" -> { if (d2 == 0) throw new NovaRuntimeError("Modulo by zero");   yield d1 % d2; }
                default  -> 0.0;
            };
        }
        throw new NovaRuntimeError("Arithmetic requires numbers, got " + typeName(L) + " and " + typeName(R));
    }

    private Object negate(Object v) { return v instanceof Long ? -(long)v : -(double)v; }
    private Object incr(Object v) { return v instanceof Long ? (long)v + 1 : (double)v + 1; }
    private Object decr(Object v) { return v instanceof Long ? (long)v - 1 : (double)v - 1; }
    private int cmp(Object a, Object b) { return Double.compare(num(a), num(b)); }
    private boolean eq(Object a, Object b) { return Objects.equals(a, b); }
    boolean truthy(Object v) { return v != null && !Boolean.FALSE.equals(v); }

    long toLong(Object v) {
        if (v instanceof Long l) return l;
        if (v instanceof Number n) return n.longValue();
        return 0L;
    }

    double num(Object v) {
        if (v instanceof Number n) return n.doubleValue();
        return 0.0;
    }

    String str(Object v) {
        if (v == null) return "null";
        if (v instanceof Boolean) return v.toString();
        if (v instanceof Double d) {
            if (d == Math.floor(d) && !d.isInfinite() && !d.isNaN()) return String.valueOf(d.longValue());
            return String.valueOf(d);
        }
        if (v instanceof List<?>) {
            StringJoiner sj = new StringJoiner(", ", "[", "]");
            for (Object item : (List<?>)v) sj.add(str(item));
            return sj.toString();
        }
        return v.toString();
    }
    private String typeName(Object v) { if (v == null) return "null"; return v.getClass().getSimpleName(); }
}

final class NovaRange implements Iterable<Object> {
    private final long from, to;
    NovaRange(long from, long to) { this.from = from; this.to = to; }
    @Override public Iterator<Object> iterator() { return new Iterator<>() { long cur = from; @Override public boolean hasNext() { return cur < to; } @Override public Object next() { return cur++; } }; }
    @Override public String toString() { return from + ".." + to; }
}